rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. DATA SYNC: Private User Data
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /batches/{batchId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ANALYTICS: Global Usage and Progress Data
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if request.auth != null;
      
      // Support for subcollections (daily/monthly activity logs)
      match /{allSubcollections=**} {
        allow read: if isAdmin();
        allow write: if request.auth != null;
      }
    }
    
    // 2. CONTROL PANEL: Global Dynamic Library
    // Any authenticated user can add resources (contributorId tracked)
    // Contributors can edit/delete their own; Admin/yashwinka8 can manage all
    match /library/{resourceId} {
      allow read: if true;
      allow create: if request.auth != null && (
        (request.resource.data.title is string && 
         request.resource.data.title.size() > 0 && 
         request.resource.data.contributorId == request.auth.uid) || 
        isAdmin()
      );
      allow update: if request.auth != null && (
        resource.data.contributorId == request.auth.uid || isAdmin()
      ) && (
        request.resource.data.contributorId == resource.data.contributorId || isAdmin()
      );
      allow delete: if request.auth != null && (
        resource.data.contributorId == request.auth.uid || isAdmin()
      );
    }
    
    // 3. GLOBAL SETTINGS: Announcement Ticker & Admins
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();

      match /history/{historyId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // 4. PUSH NOTIFICATIONS: FCM Tokens
    match /fcmTokens/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 5. NOTIFICATION RECORDS: History
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      // Allow creation of targeted notifications (e.g. access requests)
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // 6. MOCK TESTS: Dynamic Assessments
    match /mock_tests/{testId} {
      allow read: if isAdmin() || resource.data.published == true;
      allow write: if isAdmin();

      match /questions/{questionId} {
        allow read: if isAdmin() || get(/databases/$(database)/documents/mock_tests/$(testId)).data.published == true;
        allow write: if isAdmin();
      }
    }

    // 7. SHARED BATCHES
    match /shared_batches/{inviteCode} {
      // Anyone can read a specific shared batch doc (used for join-by-code flow)
      allow read: if true;
      // Listing the marketplace (isPublic == true filter is enforced client-side via query)
      // Using 'allow list: if true' because 'resource' is null in collection-level queries,
      // so checking resource.data.isPublic causes a security rule evaluation error.
      allow list: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.creatorId || 
        isAdmin() ||
        // Allow the recomputed stats fields (enrolledCount, avgCompletion) to be written
        // by any authenticated user (written via updateAvgCompletion helper)
        onlyUpdatingStatsFields()
      );
      allow delete: if request.auth != null && (
        resource.data.creatorId == request.auth.uid || 
        isAdmin()
      );
    }

    // 8. ACCESS REQUESTS
    match /access_requests/{requestId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        resource.data.ownerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        (resource.data.userId == request.auth.uid && request.resource.data.status == 'fulfilled') ||
        isAdmin()
      );
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 9. BATCH NOTIFICATIONS
    match /batch_notifications/{noticeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid || isAdmin()
      );
      allow update, delete: if isAdmin() || (request.auth != null && resource.data.ownerId == request.auth.uid);
    }

    // 10. BATCH MEMBER STATS
    match /batch_member_stats/{statId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        resource.data.ownerId == request.auth.uid || 
        isAdmin()
      );
      // Any member can write their own stats; updateAvgCompletion aggregates these
      allow create, update: if request.auth != null && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // 11. BATCH INQUIRIES
    match /batch_inquiries/{inquiryId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        resource.data.ownerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.messages.size() == 1;
      allow update: if request.auth != null && (
        (resource.data.userId == request.auth.uid || 
         resource.data.ownerId == request.auth.uid ||
         isAdmin()) &&
        request.resource.data.messages.size() > resource.data.messages.size() &&
        request.resource.data.messages.size() < 100
      );
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || isAdmin()
      );
    }

    // 12. SAMOSA SHOUTOUTS: Only yashwinka8@gmail.com can write
    match /samosa_shoutouts/{shoutoutId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && 
        request.auth.token.email == 'yashwinka8@gmail.com';
    }

    // 13. GLOBAL CALENDAR
    match /calendar/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 14. P2P DOUBT HUB
    match /doubts/{doubtId} {
      allow read: if request.auth != null; // Query filtered by batchId client-side
      allow create: if request.auth != null && 
        request.resource.data.studentId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.studentId == request.auth.uid || 
        isBatchStaff(resource.data.batchId) || 
        isAdmin()
      );
      allow delete: if isAdmin() || (request.auth != null && resource.data.studentId == request.auth.uid);
    }

    match /doubt_replies/{replyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && (
        isBatchStaff(resource.data.batchId) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // 15. BATCH STAFF OPERATIONS
    match /batch_staff/{staffId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == getBatchOwner(staffId));
    }

    // 16. COMMUNITY & CHAT
    match /communities/{groupId} {
      allow read: if request.auth != null && (
        resource.data.isPrivate == false || 
        exists(/databases/$(database)/documents/batch_member_stats/$(request.auth.uid + "_" + resource.data.batchId)) ||
        isBatchStaff(resource.data.batchId) ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == resource.data.creatorId);
    }

    match /community_messages/{msgId} {
      allow read: if request.auth != null; // Ideally filtered by groupId access
      allow create: if request.auth != null && 
        request.resource.data.senderId == request.auth.uid;
      allow delete: if isAdmin() || (request.auth != null && resource.data.senderId == request.auth.uid);
    }

    // 17. INTERACTIVE ENGAGEMENT (POLLS & ROOMS)
    match /polls/{pollId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // Only allow voting if user hasn't voted yet
        (!(request.auth.uid in resource.data.votedBy) && 
         (request.auth.uid in request.resource.data.votedBy) &&
         request.resource.data.votedBy.size() == resource.data.votedBy.size() + 1) ||
        isAdmin()
      );
    }

    match /study_rooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Ideally restricted to batch members if batchId present
    }

    // --- Helper Functions ---
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "Rf9trfhDdCWLE4H7IwbvkUUOq652" || 
        request.auth.token.email.matches("yashwinka8.*") ||
        (exists(/databases/$(database)/documents/settings/admins) && 
         request.auth.token.email.lower() in get(/databases/$(database)/documents/settings/admins).data.adminEmails)
      );
    }

    function isBatchStaff(batchId) {
      return request.auth != null && (
        exists(/databases/$(database)/documents/batch_staff/$(batchId + "_" + request.auth.uid)) ||
        isAdmin()
      );
    }

    function getBatchOwner(staffId) {
      // staffId is formatted as {batchId}_{uid}
      // This is a simplified check, in production we'd verify the batch owner
      return request.auth.uid; 
    }

    // Only updating the computed stats fields on a shared_batches doc
    function onlyUpdatingStatsFields() {
      let allowedKeys = ['avgCompletion', 'enrolledCount', 'importCount'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    // Lecture Notes
    match /lecture_notes/{noteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Lecture Resources
    match /lecture_resources/{resourceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Goals
    match /goals/{goalId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Certificates
    match /certificates/{certId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
